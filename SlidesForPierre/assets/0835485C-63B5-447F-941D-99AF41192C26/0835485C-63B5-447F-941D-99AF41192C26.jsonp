0114494237873,"x":1173.0428912639618,"width":25,"height":161.05810546875}},{"text":"signal (group galaxies)","targetRectangle":{"y":328.30369175348261,"x":88.649658203125,"width":298.31999999999994,"height":35.160003662109375}},{"text":"equation.pdf","targetRectangle":{"y":513.99843497796348,"x":885.65371078061082,"width":146.10254512500831,"height":116.32996645793958}},{"text":"But in fact we do not observe ￼ but rather have a  ￼ from SED fitting","targetRectangle":{"y":1020.6449914019367,"x":16.281235009479143,"width":1146.1706281920412,"height":47.605186368843306}},{"text":"Declination (Dec)","targetRectangle":{"y":437.26674247655842,"x":410.06362795829773,"width":25,"height":161.05810546875}},{"text":"But we can constrain the expected distribution of this noise by looking in a control line-of-sight where we know there is no galaxy group.","targetRectangle":{"y":179.07631689628937,"x":11.703103342244443,"width":1824.6600000000003,"height":35.160003662109375}},{"text":"Cluster line-of-sight","targetRectangle":{"y":265.84637779865244,"x":28.036731719970703,"width":285.42000000000002,"height":36.129791259765625}},{"text":"equation.pdf","targetRectangle":{"y":812.76927134245386,"x":23.394629599304668,"width":934.09187966792001,"height":100.55639994993214}},{"text":"Declination (Dec)","targetRectangle":{"y":437.26668144140217,"x":26.719334363937371,"width":25.000000000000007,"height":161.05810546875}},{"text":"equation.pdf","targetRectangle":{"y":871.03031264768219,"x":1027.6501981065194,"width":89.894957897448876,"height":44.3486630392199}},{"text":"equation.pdf","targetRectangle":{"y":871.03031264768219,"x":1253.6851560039684,"width":89.894957897448876,"height":44.3486630392199}},{"text":"￼","targetRectangle":{"y":19.81745982170105,"x":1867.4585218757275,"width":23.352000000000089,"height":48.824005126953125}},{"text":"Right Ascension (RA)","targetRectangle":{"y":626.29687739286396,"x":1215.6260833740234,"width":199.59228515625,"height":25}},{"text":"e.g. ￼Schechter